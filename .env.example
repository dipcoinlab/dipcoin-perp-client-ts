# =============================================================================
# DipCoin Perp Client SDK — example environment (examples/index.ts)
# Copy to `.env` and fill in your values: `cp .env.example .env`
# Run the demo with: `yarn example`
#
# High-risk actions (deposit/withdraw/orders/margin/TP-SL/vault) are gated by
# RUN_* flags and default to 0. Only enable them on testnet after verifying the
# funded account and accepting the risk.
# =============================================================================

# ---- Core ----
# Sui private key (suiprivkey... / hex / base64). Required when CHAIN=sui.
PRIVATE_KEY=
# Target network: testnet | mainnet
NETWORK=testnet
# Primary trading symbol used across the demo.
DEMO_SYMBOL=BTC-PERP
# Optional REST base URL override (defaults per network).
# API_BASE_URL=https://demoapi.dipcoin.io
# Optional Sui JSON-RPC fullnode override (defaults per network).
# CUSTOM_RPC=

# ---- Chain selection ----
# sui (default) | solana. When CHAIN=solana the demo runs the Solana CCTP +
# relayer flow (see the Solana section below) instead of the Sui flow.
# CHAIN=sui

# ---- Bank (Sui) ----
# Deposit USDC from wallet into the exchange Bank (on-chain).
RUN_DEPOSIT=0
DEPOSIT_AMOUNT=10
# Withdraw USDC from the exchange Bank back to the wallet (on-chain).
RUN_WITHDRAW=0
WITHDRAW_AMOUNT=5

# ---- Orders ----
# Place a MARKET order.
RUN_MARKET_ORDER=0
MARKET_ORDER_QTY=0.01
MARKET_ORDER_LEVERAGE=20
MARKET_ORDER_SIDE=BUY                  # BUY | SELL

# Place a LIMIT order.
RUN_LIMIT_ORDER=0
LIMIT_ORDER_QTY=0.01
LIMIT_ORDER_LEVERAGE=20
LIMIT_ORDER_PRICE=85000
LIMIT_ORDER_SIDE=BUY                   # BUY | SELL

# Cancel the first open order found for DEMO_SYMBOL.
RUN_CANCEL_ORDER=0

# ---- Market data ----
# Fetch order book + ticker snapshots (read-only; enabled by default).
RUN_MARKET_DATA=1

# ---- Leverage / margin ----
# Symbol used for leverage + margin demos (defaults to DEMO_SYMBOL).
# MARGIN_SYMBOL=BTC-PERP
# Update the preferred leverage / margin type.
RUN_ADJUST_LEVERAGE=0
MARGIN_TARGET_LEVERAGE=20
MARGIN_TYPE=ISOLATED                   # ISOLATED | CROSS
# Add / remove isolated margin on an existing position (on-chain).
RUN_MARGIN_ADD=0
MARGIN_ADD_AMOUNT=10
RUN_MARGIN_REMOVE=0
MARGIN_REMOVE_AMOUNT=5

# ---- TP / SL ----
# Place a demo take-profit / stop-loss pair for a position.
RUN_TPSL_DEMO=0
# Edit existing TP/SL plans (requires the plan ids below or live plans).
RUN_TPSL_EDIT=0
# Symbol used for the TP/SL demo (defaults to DEMO_SYMBOL).
# TPSL_SYMBOL=BTC-PERP
# Target a specific position id when fetching/placing TP/SL orders.
# POSITION_ID=
# Plan ids to edit (auto-detected from live plans when unset).
# TPSL_EDIT_TP_PLAN_ID=
# TPSL_EDIT_SL_PLAN_ID=
# Cancel a specific TP/SL order by hash (auto-detected when unset).
# TPSL_CANCEL_HASH=

# ---- Vault ----
# Run the Vault REST snapshot (overview / list / holdings / detail).
RUN_VAULT_REST=0
# Target vault id; falls back to the first vault returned by getVaultList().
# VAULT_ID=
# Follower deposit into a vault (on-chain).
RUN_VAULT_DEPOSIT=0
VAULT_DEPOSIT_AMOUNT=1
# VAULT_DEPOSIT_VAULT_ID=                # defaults to VAULT_ID
# Follower withdrawal request from a vault (on-chain).
RUN_VAULT_WITHDRAW=0
VAULT_WITHDRAW_SHARES=0.01
# VAULT_WITHDRAW_VAULT_ID=               # defaults to VAULT_ID

# =============================================================================
# Solana (CCTP + relayer) — only used when CHAIN=solana
# Solana wallets cannot pay Sui gas, so deposits bridge USDC via Circle CCTP and
# withdrawals are submitted to the DipCoin relayer. Trading/order payloads are
# signed with the Solana Ed25519 key.
# =============================================================================
# Solana private key (base58 / hex / JSON byte array; Phantom export works).
# Falls back to PRIVATE_KEY when unset.
# SOLANA_PRIVATE_KEY=
# Optional Solana RPC endpoint override (defaults to a public node per network).
# SOLANA_RPC_URL=
# Bridge USDC from Solana into the Sui Bank via CCTP.
RUN_SOLANA_DEPOSIT=0
SOLANA_DEPOSIT_AMOUNT=10
# Withdraw USDC from the Sui Bank back to the Solana wallet via the relayer.
RUN_SOLANA_WITHDRAW=0
SOLANA_WITHDRAW_AMOUNT=5
